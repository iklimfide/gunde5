{
  "buildCommand": "",
  "installCommand": "",
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/profil.html",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/itiraf", "destination": "/itiraf/index.html" },
    { "source": "/itiraf/:id", "destination": "/itiraf/index.html" }
  ]
}
